# syntax=docker/dockerfile:1
# Production image: Next.js app in apps/web (Coolify / Hetzner).
# Builder installs devDependencies (tsup, prisma, next, typescript, etc.); runner uses NODE_ENV=production.

FROM node:22-bookworm-slim AS base
RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates openssl \
  && rm -rf /var/lib/apt/lists/*
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

FROM base AS builder
ENV NEXT_TELEMETRY_DISABLED=1

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/
COPY apps/extension/package.json ./apps/extension/
COPY apps/worker/package.json ./apps/worker/

# Install devDependencies even if the host sets NODE_ENV=production (Coolify, CI).
RUN pnpm install --frozen-lockfile --prod=false

ENV NODE_ENV=production

COPY packages/shared ./packages/shared
# Bust layers below when the value changes (Coolify: Build Args / `CACHE_BUST=$(date +%s)` or "Clear Build Cache").
ARG CACHE_BUST=1
RUN echo "cache-bust=${CACHE_BUST}"
COPY apps/web ./apps/web

RUN set -eux; \
    echo "Node version:"; node -v; \
    echo "PNPM version:"; pnpm -v; \
    echo "Current dir:"; pwd; \
    echo "Root files:"; ls -la; \
    echo "Shared files:"; ls -la packages/shared; \
    echo "Shared package.json:"; cat packages/shared/package.json; \
    echo "Check tsup:"; pnpm --filter @cursor-usage-tracker/shared exec tsup --version; \
    echo "Build shared:"; pnpm --filter @cursor-usage-tracker/shared build
RUN pnpm --filter web exec prisma generate
# Writable SQLite for any build-time DB touch; runtime DATABASE_URL comes from Coolify/compose (file:/data/...).
ENV DATABASE_URL=file:/tmp/cursor-usage-build.db
# Run `next build` directly (not `pnpm --filter web build`), so stdout/stderr go to the Docker log.
# Shared + prisma generate already ran above; the web package.json build script would only nest output.
RUN set -eux; \
    echo "Build-time env check:"; \
    node -e "console.log({NODE_ENV:process.env.NODE_ENV,DATABASE_URL:process.env.DATABASE_URL?'<set>':'<missing>',TRACKER_API_KEY:process.env.TRACKER_API_KEY?'<set>':'<missing>',ADMIN_API_KEY:process.env.ADMIN_API_KEY?'<set>':'<missing>'})"; \
    cd apps/web && npx next build

FROM base AS runner
RUN apt-get update \
  && apt-get install -y --no-install-recommends curl ca-certificates openssl \
  && rm -rf /var/lib/apt/lists/*
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
COPY --from=builder /app /app
EXPOSE 3000
CMD ["sh", "-c", "pnpm --filter web exec prisma migrate deploy && pnpm --filter web start"]
