# syntax=docker/dockerfile:1
# Production image: Next.js app in apps/web (Coolify / Hetzner).
# Builder installs devDependencies (tsup, prisma, next, typescript, etc.); runner uses NODE_ENV=production.

FROM node:22-bookworm-slim AS base
RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates openssl \
  && rm -rf /var/lib/apt/lists/*
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

FROM base AS builder
ENV NEXT_TELEMETRY_DISABLED=1
# Coolify (and others) may set NODE_ENV=production during build; force dev deps for install + compile.
ENV NODE_ENV=development

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/
COPY apps/extension/package.json ./apps/extension/
COPY apps/worker/package.json ./apps/worker/

RUN pnpm install --frozen-lockfile --prod=false

COPY packages/shared ./packages/shared
COPY apps/web ./apps/web

RUN pnpm --filter @cursor-usage-tracker/shared build
RUN pnpm --filter web exec prisma generate
RUN pnpm --filter web build

FROM base AS runner
RUN apt-get update \
  && apt-get install -y --no-install-recommends curl ca-certificates openssl \
  && rm -rf /var/lib/apt/lists/*
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
COPY --from=builder /app /app
EXPOSE 3000
CMD ["sh", "-c", "pnpm --filter web exec prisma migrate deploy && pnpm --filter web start"]
